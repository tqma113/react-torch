{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://example.com/product.schema.json",
  "title": "react-torch",
  "description": "Config of react-torch",
  "type": "object",
  "properties": {
    "port": {
      "description": "Listen port.",
      "type": "integer"
    },
    "dir": {
      "description": "The dir of current project.",
      "type": "string"
    },
    "src": {
      "description": "The main dir of code.",
      "type": "string"
    },
    "mdlw": {
      "description": "The dir of middlewares.",
      "type": "string"
    },
    "ssr": {
      "description": "If need server side render.",
      "type": "boolean"
    }
  }
}