{
  "name": "react-torch",
  "version": "1.7.5",
  "description": "A lib to server-side render with react.",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "bin": {
    "torch": "./bin/torch.js"
  },
  "files": [
    "dist",
    "bin",
    "build.js",
    "build.d.ts",
    "dev.js",
    "dev.d.ts",
    "start.js",
    "start.d.ts",
    "AUTHORS",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "nodemon",
    "prebuild": "rimraf dist",
    "build": "tsc",
    "release": "node scripts/release.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "postbuild": "cp ./src/torch.d.ts ./dist/torch.d.ts",
    "format": "prettier --write --parser typescript \"{src,__tests__,example}/**/*.ts?(x)\"",
    "test": "jest --silent",
    "dev:start": "node -r ts-node/register ./example/start.ts",
    "dev:dev": "node -r ts-node/register ./example/dev.ts",
    "dev:build": "node -r ts-node/register ./example/build.ts",
    "debug:start": "node --inspect-brk -r ts-node/register ./example/start.ts",
    "debug:dev": "node --inspect-brk -r ts-node/register ./example/dev.ts",
    "commit": "git-cz",
    "precommit": "lint-staged",
    "preinstall": "node ./scripts/checkYarn.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tqma113/react-torch.git"
  },
  "keywords": [
    "react",
    "ssr",
    "server-side-render"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tqma113/react-torch/issues"
  },
  "homepage": "https://github.com/tqma113/react-torch#readme",
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "git add"
    ],
    "*.ts?(x)": [
      "prettier --parser=typescript --write",
      "git add"
    ]
  },
  "engines": {
    "node": ">= 12.0.0",
    "npm": ">= 6.0.0"
  },
  "peerDependencies": {
    "react": "^16.13.1",
    "react-dom": "^16.13.1"
  },
  "dependencies": {
    "@babel/core": "^7.10.5",
    "@babel/plugin-proposal-decorators": "^7.10.5",
    "@babel/plugin-proposal-do-expressions": "^7.10.4",
    "@babel/plugin-proposal-export-default-from": "^7.10.4",
    "@babel/plugin-proposal-export-namespace-from": "^7.10.4",
    "@babel/plugin-proposal-function-bind": "^7.10.5",
    "@babel/plugin-proposal-function-sent": "^7.10.4",
    "@babel/plugin-proposal-logical-assignment-operators": "^7.10.4",
    "@babel/plugin-proposal-pipeline-operator": "^7.10.5",
    "@babel/plugin-proposal-throw-expressions": "^7.10.4",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/preset-env": "^7.10.4",
    "@babel/preset-react": "^7.10.4",
    "@babel/preset-typescript": "^7.10.4",
    "babel-loader": "^8.1.0",
    "body-parser": "^1.19.0",
    "commander": "^4.1.1",
    "compression": "^1.7.4",
    "conventional-changelog": "^3.1.23",
    "conventional-changelog-cli": "^2.1.0",
    "cookie-parser": "^1.4.4",
    "debug": "^4.1.1",
    "express": "^4.17.1",
    "gulp": "^4.0.2",
    "gulp-clean-css": "^4.3.0",
    "gulp-plumber": "^1.2.1",
    "gulp-uglify": "^3.0.2",
    "helmet": "^3.21.3",
    "js-cookie": "^2.2.1",
    "memory-fs": "^0.5.0",
    "morgan": "^1.9.1",
    "null-loader": "^4.0.0",
    "path-to-regexp": "^3.1.0",
    "pnp-webpack-plugin": "^1.6.4",
    "query-string": "^6.11.0",
    "serve-favicon": "^2.5.0",
    "terser-webpack-plugin": "^3.0.6",
    "tiny-invariant": "^1.1.0",
    "tiny-warning": "^1.0.3",
    "webpack": "^4.41.0",
    "webpack-bundle-analyzer": "^3.5.2",
    "webpack-dev-middleware": "^3.7.2",
    "webpack-hot-middleware": "^2.25.0",
    "webpack-manifest-plugin": "^2.2.0"
  },
  "devDependencies": {
    "@types/babel-core": "^6.25.6",
    "@types/body-parser": "^1.19.0",
    "@types/commander": "^2.12.2",
    "@types/compression": "^1.7.0",
    "@types/cookie-parser": "^1.4.2",
    "@types/debug": "^4.1.5",
    "@types/express": "^4.17.2",
    "@types/gulp": "^4.0.6",
    "@types/gulp-plumber": "0.0.32",
    "@types/gulp-uglify": "^3.0.6",
    "@types/helmet": "0.0.45",
    "@types/jest": "^24.0.19",
    "@types/js-cookie": "^2.2.6",
    "@types/memory-fs": "^0.3.2",
    "@types/morgan": "^1.7.37",
    "@types/node": "^12.7.8",
    "@types/query-string": "^6.3.0",
    "@types/react": "^16.9.3",
    "@types/react-dom": "^16.9.1",
    "@types/rimraf": "^2.0.2",
    "@types/serve-favicon": "^2.5.0",
    "@types/terser-webpack-plugin": "^3.0.0",
    "@types/webpack": "^4.39.2",
    "@types/webpack-bundle-analyzer": "^2.13.3",
    "@types/webpack-dev-middleware": "^3.7.0",
    "@types/webpack-manifest-plugin": "^2.1.0",
    "commitizen": "^4.1.2",
    "jest": "^26.1.0",
    "lint-staged": "^10.2.13",
    "nodemon": "^1.19.3",
    "prettier": "^2.1.1",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "rimraf": "^3.0.2",
    "ts-jest": "^26.1.1",
    "ts-node": "^8.4.1",
    "typescript": "^4.0.2"
  }
}
